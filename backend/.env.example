# ==========================================================================
# WealthGen — Portfolio Narrative Generator  (backend/.env.example)
# Copy to .env and populate. NEVER commit .env. All values fail loudly if
# required and missing (no mocks, no fallbacks).
# ==========================================================================

# --- App ---
APP_ENV=local                       # local | prod  (local => AzureCliCredential)
CORS_ORIGINS=http://localhost:3000
JURISDICTIONS=UK,US                 # compliance rule-packs
DEFAULT_AUDIENCE=client             # client | institutional | ic

# --- Azure AI Foundry (project + agents) ---
FOUNDRY_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AGENT_MODEL=gpt-4.1

# --- Foundry IQ knowledge base (MCP grounding hub) ---
SEARCH_ENDPOINT=https://<search>.search.windows.net
KB_NAME=wealthgen-kb
KB_CONNECTION_NAME=wealthgen-kb-remote-tool     # RemoteTool project connection (see provision script)
KB_MCP_API_VERSION=2026-05-01-preview

# --- Azure AI Search (PDF source index; admin key used by provisioning only) ---
SEARCH_ADMIN_KEY=
PDF_INDEX_NAME=wealthgen-pdf-facts

# --- Azure AI Content Understanding (primary PDF path) ---
CU_ENDPOINT=https://<account>.services.ai.azure.com/
CU_ANALYZER_ID=wealthgen-factsheet-analyzer

# --- Azure AI Document Intelligence (optional deterministic fallback) ---
DI_ENDPOINT=https://<account>.services.ai.azure.com/

# --- Microsoft Fabric IQ (registered as knowledge sources) ---
FABRIC_WORKSPACE_ID=
FABRIC_DATA_AGENT_ID=
FABRIC_ONTOLOGY_ID=

# --- Azure Cosmos DB (commentary drafts, versions, audit) ---
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_DATABASE=wealthgen
COSMOS_CONTAINER=commentary

# --- LSEG market data (via MCP) ---
LSEG_MCP_URL=

# --- Azure AI Content Safety ---
CONTENT_SAFETY_ENDPOINT=https://<account>.cognitiveservices.azure.com/

# --- Blob storage (for PDF SAS URLs consumed by Content Understanding) ---
BLOB_ACCOUNT_URL=https://<account>.blob.core.windows.net
BLOB_CONTAINER=factsheets

# --- Telemetry ---
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Identity (local dev / service principal fallback only) ---
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
